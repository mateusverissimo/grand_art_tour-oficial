  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "O Armaz\xE9m Imperial: Log\xEDstica e Alf\xE2ndega\nNo s\xE9culo XIX,
    o espa\xE7o onde hoje fica o Armaz\xE9m Humberto de Maracan\xE3 operava como
    um imponente galp\xE3o aduaneiro voltado \xE0 atividade portu\xE1ria. Sua fun\xE7\xE3o
    principal era abrigar e fiscalizar toneladas de fardos de algod\xE3o e sacas
    de a\xE7\xFAcar produzidas no Maranh\xE3o, al\xE9m de receber mercadorias importadas
    da Europa. O pr\xE9dio funcionava sem divis\xF3rias internas, focado exclusivamente
    no armazenamento bruto e na for\xE7a comercial que movimentava a economia de
    S\xE3o Lu\xEDs."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
